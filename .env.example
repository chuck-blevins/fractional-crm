# Copy to .env.local and fill in.

# Database — configured in CRB-21 (userspace Postgres for dev/test).
DATABASE_URL=postgresql://app:app@localhost:5432/app

# Auth — configured in CRB-31 (NextAuth / Google OAuth).
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

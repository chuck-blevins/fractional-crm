# Fractional CRM — environment configuration (copy to .env; never commit real secrets)

# SQLite database path (defaults to ./crm.db when unset).
CRM_DB_PATH=crm.db

# Deployment environment. FAIL-SECURE: anything other than dev/development/test/testing/local
# — INCLUDING leaving this unset — is treated as PRODUCTION, which means:
#   * CRM_SESSION_SECRET becomes REQUIRED (the app refuses to start without it), and
#   * the session cookie is issued with the Secure flag (sent over HTTPS only).
# Set to "dev" for local work over plain http.
CRM_ENV=

# Session cookie signing secret. REQUIRED in production (see CRM_ENV above); the app
# refuses to start without it. In dev/test an ephemeral per-process secret is generated.
# NOTE: an ephemeral secret is per-process — never rely on it with >1 worker.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
CRM_SESSION_SECRET=

# App login passcode, stored ONLY as a PBKDF2 hash ("<salt_hex>$<digest_hex>") — never
# the plaintext. Generate from your chosen passcode with:
#   PYTHONPATH=src python -c "from fractional_crm.web.auth import hash_passcode; print(hash_passcode('YOUR_PASSCODE'))"
# Choose a HIGH-ENTROPY passcode: it is the only thing protecting the whole app.
CRM_PASSCODE_HASH=
